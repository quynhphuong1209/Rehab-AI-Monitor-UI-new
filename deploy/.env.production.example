# Copy file này thành .env.production trên VPS rồi sửa domain thật.

# Domain API trỏ về VPS, ví dụ api.rehab-ai-monitor.example.com
API_DOMAIN=api.example.com

# Domain frontend Cloudflare Pages, ví dụ https://rehab-ai-monitor.pages.dev
FRONTEND_ORIGIN=https://your-project.pages.dev

# Secret dài/ngẫu nhiên để ký token đăng nhập.
# Tạo nhanh: openssl rand -hex 32
REHAB_TOKEN_SECRET=change-this-to-a-long-random-secret

# Dữ liệu runtime trên VPS. Giữ nguyên các thư mục này để không mất dữ liệu.
REHAB_REPO_ROOT=/app
REHAB_DATABASE_DIR=/app/database
REHAB_DATASET_DIR=/app/database/dataset
REHAB_UPLOAD_MAX_MB=600
REHAB_UPLOAD_MAX_SIZE=700MB

# Thường để trống. Chỉ dùng khi cần cho phép nhiều domain frontend, phân tách bằng dấu phẩy.
REHAB_CORS_ORIGIN_REGEX=

# Nếu dùng Hugging Face Dataset làm mirror/backup thì đặt token ở đây.
HF_TOKEN=
HF_DATASET_ID=quynhphuong1209/Rehab-AI-Monitor-2026-data
HF_BUCKET_ID=quynhphuong1209/Rehab-AI-Monitor-2026-storage
